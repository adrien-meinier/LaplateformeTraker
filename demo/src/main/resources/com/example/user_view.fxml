<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.controller.UserController">

    <Label text="User Management"/>

    <TextField fx:id="emailField" promptText="Email"/>
    <PasswordField fx:id="passwordField" promptText="Password"/>

    <CheckBox fx:id="adminCheckBox" text="Admin"/>

    <Button text="Login" onAction="#handleLogin"/>
    <Button text="Register" onAction="#handleRegister"/>
    <Button text="Delete User" onAction="#handleDelete"/>
    <Button text="Update Password" onAction="#handleUpdatePassword"/>

    <Label fx:id="messageLabel"/>

</VBox>