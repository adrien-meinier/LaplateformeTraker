<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="700.0" prefWidth="1100.0" spacing="20.0" style="-fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controller.StudentController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <children>
                <Label text="👨‍🎓 Gestion des Étudiants" textFill="#2c3e50">
                    <font>
                        <Font name="System Bold" size="26.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleExportAll" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" text="📥 Exporter Tout" />
            </children>
        </HBox>

        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
            <children>
                <VBox prefWidth="320.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5);">
                    <padding>
                        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                    </padding>
                    <children>
                        <VBox alignment="CENTER" spacing="10.0">
                            <children>
                                <StackPane maxWidth="110.0" style="-fx-border-color: #3498db; -fx-border-width: 2; -fx-border-radius: 60; -fx-padding: 3;">
                                    <children>
                                        <ImageView fx:id="profileImageView" fitHeight="100.0" fitWidth="100.0" pickOnBounds="true">
                                            <image>
                                                <Image url="https://openmoji.org/data/color/svg/1F916.svg" />
                                            </image>
                                        </ImageView>
                                    </children>
                                </StackPane>
                                <Label text="Avatar de l'étudiant" style="-fx-font-weight: bold;" textFill="#7f8c8d" />
                                <ComboBox fx:id="avatarComboBox" maxWidth="Infinity" onAction="#onAvatarChanged" promptText="Choisir un avatar..." style="-fx-background-radius: 5;" />
                            </children>
                        </VBox>

                        <Separator />

                        <VBox spacing="12.0">
                            <children>
                                <VBox spacing="5.0">
                                    <Label style="-fx-font-weight: bold;" text="Prénom" />
                                    <TextField fx:id="firstNameField" promptText="Ex: Jean" style="-fx-background-radius: 5;" />
                                </VBox>
                                <VBox spacing="5.0">
                                    <Label style="-fx-font-weight: bold;" text="Nom" />
                                    <TextField fx:id="lastNameField" promptText="Ex: Dupont" style="-fx-background-radius: 5;" />
                                </VBox>
                                <VBox spacing="5.0">
                                    <Label style="-fx-font-weight: bold;" text="Date de naissance" />
                                    <DatePicker fx:id="birthDatePicker" maxWidth="Infinity" />
                                </VBox>
                            </children>
                        </VBox>

                        <Region VBox.vgrow="ALWAYS" />

                        <VBox spacing="10.0">
                            <Button maxWidth="Infinity" onAction="#handleAdd" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-cursor: hand;" text="AJOUTER" />
                            <Button maxWidth="Infinity" onAction="#handleUpdate" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-cursor: hand;" text="MODIFIER" />
                            <Button maxWidth="Infinity" onAction="#handleDelete" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-cursor: hand;" text="SUPPRIMER" />
                        </VBox>
                    </children>
                </VBox>

                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                    <children>
                        <TableView fx:id="studentTable" style="-fx-background-radius: 10;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                                <TableColumn fx:id="colFirstName" prefWidth="150.0" text="Prénom" />
                                <TableColumn fx:id="colLastName" prefWidth="150.0" text="Nom" />
                                <TableColumn fx:id="colBirthDate" prefWidth="130.0" text="Naissance" />
                                <TableColumn fx:id="colCreationDate" prefWidth="130.0" text="Créé le" />
                                <TableColumn fx:id="colLastModifiedDate" prefWidth="130.0" text="Modifié le" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                        
                        <HBox alignment="CENTER" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 10;">
                            <children>
                                <Button fx:id="btnPrev" style="-fx-cursor: hand;" text="◀" />
                                <Label fx:id="lblPagination" style="-fx-font-weight: bold;" text="Page 1 / 1" />
                                <Button fx:id="btnNext" style="-fx-cursor: hand;" text="▶" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>