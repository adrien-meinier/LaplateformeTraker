<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="900.0" spacing="20.0" style="-fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controller.StudentController">
    <children>
        <Label text="Gestion des Étudiants" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>

        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
            <children>
                <VBox prefWidth="300.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        <Label text="Informations" textFill="#7f8c8d">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Label>
                        
                        <VBox spacing="5.0">
                            <Label text="Prénom" />
                            <TextField fx:id="firstNameField" promptText="Jean" style="-fx-background-radius: 5;" />
                        </VBox>

                        <VBox spacing="5.0">
                            <Label text="Nom" />
                            <TextField fx:id="lastNameField" promptText="Dupont" style="-fx-background-radius: 5;" />
                        </VBox>

                        <VBox spacing="5.0">
                            <Label text="Date de naissance" />
                            <DatePicker fx:id="birthDatePicker" maxWidth="1.1754943508222875E308" />
                        </VBox>

                        <Region VBox.vgrow="ALWAYS" />

                        <VBox spacing="10.0">
                            <Button maxWidth="1.1754943508222875E308" onAction="#handleAdd" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Ajouter" />
                            <Button maxWidth="1.1754943508222875E308" onAction="#handleUpdate" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Modifier" />
                            <Button maxWidth="1.1754943508222875E308" onAction="#handleDelete" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Supprimer" />
                        </VBox>
                    </children>
                </VBox>

                <TableView fx:id="studentTable" HBox.hgrow="ALWAYS" style="-fx-background-radius: 10;">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                        <TableColumn fx:id="colFirstName" prefWidth="120.0" text="Prénom" />
                        <TableColumn fx:id="colLastName" prefWidth="120.0" text="Nom" />
                        <TableColumn fx:id="colBirthDate" prefWidth="120.0" text="Naissance" />
                        <TableColumn fx:id="colCreationDate" prefWidth="120.0" text="Créé le" />
                        <TableColumn fx:id="colLastModifiedDate" prefWidth="120.0" text="Modifié le" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>