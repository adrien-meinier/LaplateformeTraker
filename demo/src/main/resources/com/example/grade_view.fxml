<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.controller.GradeController">

    <Label text="Grade Management"/>

    <TextField fx:id="studentIdField" promptText="Student ID"/>
    <TextField fx:id="gradeField" promptText="Grade"/>
    <TextField fx:id="subjectField" promptText="Subject"/>
    <TextField fx:id="gradeIdField" promptText="Grade ID"/>

    <Button text="Add Grade" onAction="#handleAddGrade"/>
    <Button text="Update Grade" onAction="#handleUpdateGrade"/>
    <Button text="Delete Grade" onAction="#handleDeleteGrade"/>
    <Button text="Get Grade by ID" onAction="#handleGetGradeById"/>
    <Button text="Get Grades by Student" onAction="#handleGetGradesByStudent"/>
    <Button text="Get All Grades" onAction="#handleGetAllGrades"/>

    <TextArea fx:id="resultArea" prefHeight="200"/>

    <Label fx:id="messageLabel"/>

</VBox>